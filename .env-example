GOOGLE_API_KEY=GOOGLE_API_KEY
GROQ_API_KEY=GROQ_API_KEY
SMTP_HOST=SMTP_HOST
SMTP_PORT=SMTP_PORT
SMTP_USER=SMTP_USER
SMTP_PASS=SMTP_PASS
USE_MODEL=gemini-2.5-flash-lite
LANGUAGE=es

# OAuth2 Server - Comunicación con el servidor de autenticación
OAUTH2_URL=http://host.docker.internal:8080
PUBLIC_OAUTH2_URL=http://localhost:8080
PUBLIC_REDIRECT_URI=http://localhost:9000/oauth/callback

# Endpoints OAuth2
OAUTH2_TOKEN_ENDPOINT=/oauth/token
OAUTH2_USERINFO_ENDPOINT=/user/me

# Credenciales OAuth2 (debes configurar estas en tu .env)
OAUTH2_CLIENT_ID=transcriberapp
OAUTH2_CLIENT_SECRET=tu_client_secret_aqui

# Ruta para almacenar los datos de transcripción
# TRANSCRIBER_DATA=C:/path/to/transcriber  # Windows
TRANSCRIBER_DATA=/path/to/transcriber   # Linux/Mac

# Timeout configurations (in seconds)
# FFmpeg API timeouts
FFMPEG_TIMEOUT_HEALTH=5
FFMPEG_TIMEOUT_GPU_STATUS=5
FFMPEG_TIMEOUT_ENDPOINT_CHECK=10
FFMPEG_TIMEOUT_AUDIO_INFO=30
FFMPEG_TIMEOUT_CONVERT=300
FFMPEG_TIMEOUT_CHUNKED=300
FFMPEG_TIMEOUT_CLEAN=300
FFMPEG_TIMEOUT_VALIDATE=300
FFMPEG_TIMEOUT_READY=30

# Groq transcribe timeouts
GROQ_TIMEOUT_FFMPEG_READY=10
FFPROBE_TIMEOUT=10
GROQ_TIMEOUT_API=300

# Email timeouts
SMTP_TIMEOUT=30

# OAuth timeouts
OAUTH_TIMEOUT_HTTP=30.0